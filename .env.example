# Configurações de Ambiente - NutixoApp

# Supabase Configuration
# Get these from your Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here

VITE_NVIDIA_API_KEY=nvapi-your-key-here
VITE_AI_MODEL=meta/llama-3.2-11b-vision-instruct

# Gemini
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Importação via backend-python
VITE_IMPORT_USE_BACKEND=true
VITE_IMPORT_BACKEND_URL=/py-api

# Application Settings
VITE_APP_NAME=NutixoApp
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_GAMIFICATION=true
VITE_DEBUG_MODE=false
VITE_ENABLE_AI_LOGGING=true
