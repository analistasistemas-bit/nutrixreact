# Configurações de Ambiente - NutixoApp

# InsForge Configuration
# Get these from your InsForge dashboard
VITE_INSFORGE_PROJECT_ID=your_project_id
VITE_INSFORGE_ANON_KEY=your_anon_key_here
VITE_INSFORGE_BASE_URL=https://your-project.insforge.app

# Application Settings
VITE_APP_NAME=NutixoApp
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_GAMIFICATION=true
VITE_DEBUG_MODE=false
